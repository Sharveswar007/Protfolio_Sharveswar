---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero';
import About from '../components/About';
import Skills from '../components/Skills';
import Experience from '../components/Experience';
import Projects from '../components/Projects';
import Awards from '../components/Awards';
import Contact from '../components/Contact';
---

<Layout title="Sharveswar Madasamy | AI Integrated Full Stack Developer" url="https://portfolio-sharveswar.vercel.app">
	<!-- Hero Section -->
	<Hero client:load />

	<!-- About Section -->
	<About client:load />

	<!-- Skills Section -->
	<Skills client:visible />

	<!-- Experience Section -->
	<Experience client:visible />

	<!-- Projects Horizontal Section -->
	<Projects client:visible />

	<!-- Awards & Certifications Section -->
	<Awards client:load />

	<!-- Visual Spacer before Contact Footer Reveal -->
	<div class="h-24 bg-midnight-black light:bg-cream-ivory relative z-20 border-t border-white/5 light:border-black/5"></div>

	<!-- Contact Curtain Reveal Footer -->
	<Contact client:load />
</Layout>
